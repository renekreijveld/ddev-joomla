#!/bin/bash
# jbackup -- backup a Joomla website to a tar.gz or .zip file
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history
# 1.0 Initial version
# 1.1 Added option to save the backup in the backupfolder
# 1.2 Added better restore intructions
# 1.3 ShellCheck fixes

VERSION=1.3

# Name of this script
MYNAME=$(basename "$0")

# Get DDEV Joomla configuration from ~/.config/ddevjoomla/config
CONFIG_DIR="${HOME}/.config/ddevjoomla"
CONFIG_FILE="${CONFIG_DIR}/config"

# Load configuration file defaults
if [[ -f "${CONFIG_FILE}" ]]; then
    # shellcheck source=/dev/null
    source "${CONFIG_FILE}"
else
    echo "Error: configuration file ${CONFIG_FILE} not found, exiting."
    exit 1
fi

# show message function
showmessage() {
    if [ "${SILENT}" == "no" ]; then
        echo -e "$1"
    fi
}

# display usage information
usage() {
    echo -e "\n${MYNAME} ${VERSION}, written by René Kreijveld.\n"
    echo -e "Usage: ${MYNAME} [-n <name>] [-b] [-z] [-t] [-o] [-s] [-h]\n"
    echo "Default action is .tgz backup."
    echo "-n the name for the website to backup."
    echo "-b Save the backup in the backup folder."
    echo "-z Zip. Backup to a zipfile instead of a tgzfile."
    echo "-t Add a date/time-stamp to the backup file."
    echo "-o Overwrite existing backupfile and/or database dump."
    echo "-s silent, no messages will be shown (optional)."
    echo -e "-h Help. Display this info.\n"
    exit 0
}

WEBSITE_NAME=""
USEBACKUPFOLDER="no"
ZIP="no"
TIMESTAMP="no"
OVERWRITE="no"
SILENT="no"
while getopts n:bztosh opt; do
    case "${opt}" in
    n)
        WEBSITE_NAME=$OPTARG
        ;;
    b)
        USEBACKUPFOLDER="yes"
        ;;
    z)
        ZIP="yes"
        ;;
    t)
        TIMESTAMP="yes"
        ;;
    o)
        OVERWRITE="yes"
        ;;
    s)
        SILENT="yes"
        ;;
    h)
        usage
        ;;
    \?)
        echo "Invalid option: -$OPTARG" >&2
        usage
        ;;
    esac
done

# create date/time stamp
if [ "${TIMESTAMP}" == "yes" ]; then
    NOW=$(date +".%Y%m%d.%H%M%S")
else
    NOW=""
fi

showmessage "${MYNAME} ${VERSION}"

# If no website name given, derive it from the current directory
if [ -n "${WEBSITE_NAME}" ]; then
    # shellcheck disable=SC2153
    WEBSITE_FOLDER="${ROOTFOLDER}/${WEBSITE_NAME}"
    if [ ! -d "${WEBSITE_FOLDER}" ]; then
        echo "Error: website folder ${WEBSITE_FOLDER} not found, exiting."
        exit 1
    fi
    cd "${WEBSITE_FOLDER}" || exit 1
else
    WEBSITE_NAME=$(basename "$PWD")
fi

# Check if the database dump must be stored in the backupfolder.
# If not, the backupfile is stored in the root folder of the project
if [[ "${USEBACKUPFOLDER}" == "yes" ]]; then
    OUTFOLDER="${BACKUPFOLDER}/sites/"
else
    OUTFOLDER="${ROOTFOLDER}/${WEBSITE_NAME}/"
fi

START_FOLDER="$PWD"

# Check if database dump exists
if [ -e db.sql.gz ]; then
    if [ "${OVERWRITE}" == "no" ]; then
        read -r -p "Database dump db.sql.gz already exists. Press Enter to overwrite, or Ctrl-C to abort."
    fi
fi

# Build backup file path
if [ "${ZIP}" == "no" ]; then
    BACKUPFILE="${OUTFOLDER}${WEBSITE_NAME}${NOW}.tgz"
else
    BACKUPFILE="${OUTFOLDER}${WEBSITE_NAME}${NOW}.zip"
fi

# Check if backup file exists
if [ -e "${BACKUPFILE}" ]; then
    if [ "${OVERWRITE}" == "no" ]; then
        read -r -p "Backup ${BACKUPFILE} already exists. Press Enter to overwrite, or Ctrl-C to abort."
    fi
fi

showmessage "Create database dump."
if ! ddev export-db --file=db.sql.gz >/dev/null 2>&1; then
    echo "Error: database dump failed, exiting."
    exit 1
fi

showmessage "Create backup."

# create the backup (dotglob ensures hidden files/folders are included)
shopt -s dotglob
if [ "${ZIP}" == "no" ]; then
    tar czf "${BACKUPFILE}" ./*
else
    zip -q -r "${BACKUPFILE}" ./*
fi
shopt -u dotglob

rm -f db.sql.gz

showmessage "\nYour backup is ready at ${BACKUPFILE}.\n"
# Present restore instructions
if [ "${ZIP}" == "no" ]; then
    showmessage "To restore this backup do the following:\n\ncd ${START_FOLDER}\ntar xzf ${BACKUPFILE}"
else
    showmessage "To restore this backup do the following:\n\ncd ${START_FOLDER}\nunzip -q -o ${BACKUPFILE}"
fi
