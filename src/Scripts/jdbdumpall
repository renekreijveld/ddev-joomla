#!/bin/bash

# jdbdumpall -- Create a database dump of all DDEV Joomla projects
# Supports Joomla versions 1.0 - 5.x
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history:
# 1.0 Initial version
# 1.1 Display folder name where database dumps are stored.

VERSION=1.1

# Name of this script
MYNAME=$(basename "$0")

# Get DDEV Joomla configuration from ~/.config/ddevjoomla/config
CONFIG_DIR="${HOME}/.config/ddevjoomla"
CONFIG_FILE="${CONFIG_DIR}/config"

# Load configuration file defaults
if [[ -f "${CONFIG_FILE}" ]]; then
    source "${CONFIG_FILE}"
else
    echo "Error: configuration file ${CONFIG_FILE} not found, exiting."
    exit 1
fi

# Function to show messages (honoring silent mode)
showmessage() {
    if [[ "${SILENT}" == "no" ]]; then
        echo -e "$1"
    fi
}

# Display usage information
usage() {
    echo -e "${MYNAME} ${VERSION}, written by René Kreijveld.\n"
    echo -e "Usage: ${MYNAME} [-n] [-v] [-s] [-h]\n"
    echo "-n Do not compress the database dump with gzip."
    echo "-v Verbose, show all ddev output (optional)."
    echo "-s Silent mode, no messages will be shown."
    echo -e "-h Help. Display this info.\n"
    exit 0
}

# Process the arguments
COMPRESS=""
VERBOSE=""
SILENT="no"
while getopts "nvsh" opt; do
    case "${opt}" in
    n)
        COMPRESS="-n"
        ;;
    v)
        VERBOSE="-v"
        ;;
    s)
        SILENT="yes"
        ;;
    h)
        usage
        ;;
    \?)
        echo "Invalid option: -$OPTARG" >&2;
        exit 1
        ;;
    esac
done

showmessage "${MYNAME} ${VERSION}"

# Scan for Joomla installations by looking for configuration.php
while read -r CONFFILE; do
    DIR=$(dirname "${CONFFILE}")
    cd "${DIR}" || continue

    WEBSITE_NAME=$(basename "$PWD")

    # Create database dump
    /usr/local/bin/jdbdump -b -t ${COMPRESS} -s < /dev/null
    showmessage "Database dump created for project ${WEBSITE_NAME}."
done < <(find "${ROOTFOLDER}" -maxdepth 2 -name "configuration.php" -type f | sort)
showmessage "All databasedumps are ready in folder ${BACKUPFOLDER}/databases."