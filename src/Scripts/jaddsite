#!/bin/bash

# jaddsite - add a new Joomla site to DDEV
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history
# 1.0 Initial version
# 1.1 Added option to specify webserver type (nginx/apache)
# 1.2 Added -v verbose option
# 1.3 Added Adminer add-on installation before restarting DDEV

# Variables

# version
VERSION=1.3
# name of this
MYNAME=$(basename "${0}")

# root folder for websites
CONFIG_DIR="${HOME}/.config/ddevjoomla"
CONFIG_FILE="${CONFIG_DIR}/config"

# show message function
showmessage() {
    if [ "${SILENT}" == "no" ]; then
        echo -e "$1"
    fi
}

# Load configuration file defaults
if [[ -f "${CONFIG_FILE}" ]]; then
    source "${CONFIG_FILE}"
else
    echo "Error: configuration file ${CONFIG_FILE} not found, exiting."
    exit 1
fi

# Set default webserver from config if not already set
DEFAULT_WEBSERVER="${WEBSERVER:-nginx}"

# display usage information
usage() {
    echo -e "${MYNAME} ${VERSION}, written by René Kreijveld. Add a new Joomla site to DDEV.\n"
    echo -e "Usage: ${MYNAME} -n <sitename> [-p <php_version>] [-w <webserver>] [-j] [-v] [-s] [-h]\n"
    echo "-n the website name for the new website (without spaces)."
    echo "-p the PHP version for the new website (optional, default: 8.4)."
    echo "-w the webserver to use, nginx or apache (optional, default: ${DEFAULT_WEBSERVER})."
    echo "-j download and install Joomla (optional)."
    echo "-v verbose, show all ddev output (optional)."
    echo "-s silent, no messages will be shown (optional)."
    echo -e "-h display this help (optional).\n"
    exit 0
}

# Function to check if the site name contains spaces
contains_spaces() {
    if [[ "$1" =~ \  ]]; then
        return 0
    else
        return 1
    fi
}

# Parse command line arguments
SILENT="no"
VERBOSE="no"
JOOMLA="no"
PHP_VERSION="8.4"
WEBSERVER_OPTION=""
while getopts "n:p:w:ijvsh" opt; do
    case ${opt} in
    n)
        WEBSITE_NAME=$OPTARG
        ;;
    p)
        PHP_VERSION=$OPTARG
        ;;
    w)
        WEBSERVER_OPTION=$OPTARG
        ;;
    i)
        IGNOREFOLDER="yes"
        ;;
    j)
        JOOMLA="yes"
        ;;
    v)
        VERBOSE="yes"
        ;;
    s)
        SILENT="yes"
        ;;
    h)
        usage
        ;;
    \?)
        echo "Invalid option: -$OPTARG" >&2
        usage
        ;;
    :)
        echo "Option -$OPTARG requires an argument." >&2
        usage
        ;;
    esac
done

showmessage "${MYNAME} ${VERSION}, add a new Joomla site to DDEV"

# Check if ddev is installed
if ! command -v ddev &>/dev/null; then
    echo "Error: ddev is not installed or not in PATH, exiting."
    exit 1
fi

# Use command-line webserver if provided, otherwise use config default
if [ -n "${WEBSERVER_OPTION}" ]; then
    WEBSERVER="${WEBSERVER_OPTION}"
fi

# Validate webserver option
if [[ -z "${WEBSERVER}" || ( "${WEBSERVER}" != "nginx" && "${WEBSERVER}" != "apache" ) ]]; then
    echo "Error: invalid or missing webserver '${WEBSERVER}'."
    echo "Valid options are: nginx or apache"
    echo "Use ${MYNAME} -h to display help."
    exit 1
fi

# check if mandatory parameters are provided
if [ -z "${WEBSITE_NAME}" ]; then
    echo "Error: website name missing."
    echo "Use ${MYNAME} -h to display help."
    exit 1
fi


# check if the site name contains spaces
if contains_spaces "${WEBSITE_NAME}"; then
    echo "Error: Site name '${WEBSITE_NAME}' contains spaces."
    echo "Use ${MYNAME} -h to display help."
    exit 1
fi

showmessage "Add new website ${WEBSITE_NAME} to DDEV."

# Set website root folder
SITE_FOLDER=${ROOTFOLDER}/${WEBSITE_NAME}

# Ask for confirmation before proceeding
echo -e "Ready to set up website '${WEBSITE_NAME}' with PHP ${PHP_VERSION} using ${WEBSERVER} in ${SITE_FOLDER}."
read -r -p "Do you want to continue? [Y/n] " CONFIRM
if [[ ! "${CONFIRM}" =~ ^[Yy]?$ ]]; then
    echo "Aborted."
    exit 0
fi

# Redirect ddev output based on -v flag
if [ "${VERBOSE}" == "yes" ]; then
    CMD_OUTPUT=/dev/stdout
else
    CMD_OUTPUT=/dev/null
fi

# Create the website directory and optionally add an index.php
if [ -d "${SITE_FOLDER}" ]; then
    showmessage "Website folder ${SITE_FOLDER} already exists, using existing folder."
else
    showmessage "Create website root folder ${SITE_FOLDER}."
    mkdir -p "${SITE_FOLDER}"
fi

cd "${SITE_FOLDER}"

# Download and unzip Joomla if needed
if [ "${JOOMLA}" == "yes" ]; then
    showmessage "Downloading and extracting latest Joomla"
    jlatest -s
else
    echo "<!DOCTYPE html><html><head><title>Empty DDEV php ${PHP_VERSION} website</title></head><body><h1>This is an empty DDEV website running on PHP version ${PHP_VERSION}</h1></body></html>" > index.php
    chmod 644 index.php
fi

# Create DDEV config
showmessage "Creating DDEV config"
ddev config --project-type=php --webserver-type=${WEBSERVER}-fpm --docroot=. --php-version="${PHP_VERSION}" --upload-dirs=images >"${CMD_OUTPUT}" 2>&1

# Add joomla.ini
echo "display_errors = off" > "${SITE_FOLDER}/.ddev/php/joomla.ini"
echo "output_buffering = off" >> "${SITE_FOLDER}/.ddev/php/joomla.ini"

# Start DDEV
showmessage "Starting DDEV project"
ddev start >"${CMD_OUTPUT}" 2>&1

# Configure based on selected webserver
if [[ "${WEBSERVER}" == "nginx" ]]; then
    # Modify the nginx-site.conf
    NGINXCONF="${SITE_FOLDER}/.ddev/nginx_full/nginx-site.conf"

    # Remove the #ddev-generated line so DDEV does not overwrite our customisations
    sed -i.bak '/^#ddev-generated/d' "${NGINXCONF}"
    rm -f "${NGINXCONF}.bak"

    # Add Joomla API support before the @rewrite location block
    awk '/location @rewrite \{/{
        print "    # Support for Joomla API"
        print "    location /api/ {"
        print "        try_files $uri $uri/ /api/index.php?$args;"
        print "    }"
        print ""
    }
    {print}' "${NGINXCONF}" > "${NGINXCONF}.tmp" && mv "${NGINXCONF}.tmp" "${NGINXCONF}"
fi

# Add Adminer to the project
showmessage "Adding Adminer to the project"
ddev add-on get ddev/ddev-adminer >"${CMD_OUTPUT}" 2>&1

showmessage "Restarting DDEV project"
ddev restart >"${CMD_OUTPUT}" 2>&1

# Run Joomla installer if needed
if [ "${JOOMLA}" == "yes" ]; then
    showmessage "Run Joomla installer"
    DB_PREFIX=$(cat /dev/urandom | LC_ALL=C tr -dc 'a-z' | head -c 5)
    ddev php installation/joomla.php install --site-name="Joomla" --admin-user="Administrator" --admin-username=admin --admin-password=AdminAdmin1! --admin-email=admin@example.com --db-type=mysqli --db-encryption=0 --db-host=db --db-user=db --db-pass="db" --db-name=db --db-prefix=${DB_PREFIX}_ --public-folder="" >"${CMD_OUTPUT}" 2>&1
    showmessage "Joomla config set sef_rewrite to true"
    ddev php cli/joomla.php config:set sef_rewrite=true >"${CMD_OUTPUT}" 2>&1
    showmessage "Joomla config set session lifetime to 120 minutes"
    ddev php cli/joomla.php config:set lifetime=120 >"${CMD_OUTPUT}" 2>&1

    # When webserver is apache, create a .htaccess
    if [[ "${WEBSERVER}" == "apache" ]]; then
        showmessage "Your webserver is apache, checking for presence of .htaccess."
        if [[ -f "${SITE_FOLDER}/.htaccess" ]]; then
            showmessage "A .htaccess file was already found, no change needed."
        else
            cp "${SITE_FOLDER}/htaccess.txt" "${SITE_FOLDER}/.htaccess"
        fi
    fi

    echo -e "Your Joomla website is ready.\n"
    echo -e "The website URL is https://${WEBSITE_NAME}.ddev.site"
    echo -e "Administrator URL is https://${WEBSITE_NAME}.ddev.site/administrator"
    echo -e "Admin username is admin"
    echo -e "Admin password is AdminAdmin1!\n"
fi

ddev describe >"${CMD_OUTPUT}" 2>&1
echo -e "Launch your website with the command: ddev launch"
